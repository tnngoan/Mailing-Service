generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Campaign {
  id              Int         @id @default(autoincrement())
  subject         String
  content         String
  status          String      @default("pending") // pending | sending | paused | completed | failed
  totalRecipients Int         @default(0)
  sentCount       Int         @default(0)
  failedCount     Int         @default(0)
  errorMessage    String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  recipients      Recipient[]
}

model Recipient {
  id           Int       @id @default(autoincrement())
  campaignId   Int
  email        String
  status       String    @default("pending") // pending | sent | failed
  provider     String?
  sentAt       DateTime?
  error        String?
  batchDay     Int?
  priority     Int       @default(2)
  autoIncluded Boolean   @default(false) // true = auto-added from contacts DB (lowest tier, gets bumped)
  campaign     Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, status])
  @@index([campaignId, batchDay])
  @@index([campaignId, status, priority])
}

model Contact {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  createdAt DateTime @default(now())
  source    String   @default("csv-upload")
}
