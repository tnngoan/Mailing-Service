# Sender identity (used by ALL providers)
SENDER_EMAIL=you@yourdomain.com
SENDER_NAME=Your Newsletter

# --- Email Providers (ordered by free-tier daily limit) ---
# Add API keys for as many as you want. The app auto-detects which
# are configured and splits emails proportional to their daily limits.
# All 10 providers combined: up to 1,850/day free.

# 1. SendPulse (free: 400/day, 12K/month, 50/hour)
#    Sign up: https://sendpulse.com → Settings → API
# SENDPULSE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDPULSE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SENDPULSE_DAILY_LIMIT=400

# 2. Brevo / Sendinblue (free: 300/day, 9K/month)
#    Sign up: https://app.brevo.com → Settings → SMTP & API → API Keys
# BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# BREVO_DAILY_LIMIT=300

# 3. SMTP2GO (free: 200/day, 1K/month)
#    Sign up: https://www.smtp2go.com → Settings → API Keys
# SMTP2GO_API_KEY=api-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# SMTP2GO_DAILY_LIMIT=200

# 4. Mailjet (free: 200/day, 6K/month)
#    Sign up: https://app.mailjet.com → Account Settings → API Keys
# MAILJET_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILJET_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILJET_DAILY_LIMIT=200

# 5. Mailtrap (free: 150/day, 4K/month)
#    Sign up: https://mailtrap.io → Sending Domains → API Tokens
# MAILTRAP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILTRAP_DAILY_LIMIT=150

# 6. SendGrid (free trial: 100/day — trial expires after 60 days)
#    Sign up: https://app.sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_DAILY_LIMIT=100

# 7. Maileroo (free: 100/day, 3K/month)
#    Sign up: https://maileroo.com → Dashboard → API Keys
# MAILEROO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MAILEROO_DAILY_LIMIT=100

# 8. Elastic Email (free: 100/day, 3K/month)
#    Sign up: https://elasticemail.com → Settings → API Keys
# ELASTICEMAIL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ELASTICEMAIL_DAILY_LIMIT=100

# 9. Mailgun (free: 100/day — requires credit card)
#    Sign up: https://app.mailgun.com → API Keys
# MAILGUN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxx-xxxxxxxx
# MAILGUN_DOMAIN=mg.yourdomain.com
# MAILGUN_DAILY_LIMIT=100

# 10. Resend (free: 100/day, 3K/month)
#     Sign up: https://resend.com → API Keys
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_DAILY_LIMIT=100

# Database (SQLite)
DATABASE_URL="file:./dev.db"
